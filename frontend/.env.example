# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# Target blockchain chain ID (decimal). Hardhat: 31337 | Sepolia: 11155111 | Polygon Amoy: 80002
# ⚠️ WAJIB diset di production! Jika tidak diset, fallback ke 31337 (Hardhat Localhost).
NEXT_PUBLIC_CHAIN_ID=31337

# Human-readable chain name (ditampilkan ke user saat switch network)
NEXT_PUBLIC_CHAIN_NAME=Hardhat Localhost

# Blockchain RPC URL — dipakai saat MetaMask belum punya network ini (wallet_addEthereumChain)
# Localhost: http://localhost:8545 | Sepolia: https://rpc.sepolia.org | Amoy: https://rpc-amoy.polygon.technology
NEXT_PUBLIC_RPC_URL=http://localhost:8545

# Voting System Contract Address
NEXT_PUBLIC_VOTING_SYSTEM_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Block Explorer base URL (no trailing slash). Examples: https://amoy.polygonscan.com, https://sepolia.etherscan.io
NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

# Block number when the VotingSystem contract was first deployed.
# Setting this avoids scanning from block 0 and speeds up tx hash lookups significantly.
# Find it on Etherscan/Polygonscan on the contract's page.
NEXT_PUBLIC_CONTRACT_DEPLOY_BLOCK=0
